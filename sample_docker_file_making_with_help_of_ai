services:
  mysql:
    image: mysql:8.4
    container_name: rental_mysql
    environment:
      MYSQL_ROOT_PASSWORD: ${DB_PASSWORD:-admin}
      MYSQL_DATABASE: ${DB_NAME:-house_rental_db}
    ports:
      - "3306:3306"
    volumes:
      - mysql_data:/var/lib/mysql
      - ./database/schema.sql:/docker-entrypoint-initdb.d/01-schema.sql

  backend:
    build:
      context: ./backend
    container_name: rental_backend
    env_file:
      - .env
    ports:
      - "8080:8080"
    depends_on:
      - mysql
    volumes:
      - ./uploads:/app/uploads

  frontend:
    build:
      context: ./frontend
      args:
        VITE_API_BASE_URL: ${VITE_API_BASE_URL:-http://localhost:8080/api}
        VITE_BACKEND_ORIGIN: ${VITE_BACKEND_ORIGIN:-http://localhost:8080}
    container_name: rental_frontend
    ports:
      - "5173:80"
    depends_on:
      - backend

volumes:
  mysql_data:
